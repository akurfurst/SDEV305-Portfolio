<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles/admin.css">
    <title>Confirmed</title>
</head>
<body>
    <nav>
        <a href="/"><p>Home</p></a>
        <a href="/contact"><p>Contact</p></a>
        <a href="/admin"><p>Admin</p></a>
        <a href="https://github.com/akurfurst"  target="_blank"><p>GitHub</p></a>
        <a href="https://linkedin.com/in/adam-kurfurst-3064481b2" target="_blank"><p>LinkedIn</p></a>
    </nav>
    <h1>Confirmed!</h1>
    <p>Name: <%= contact.fname %> <%= contact.lname %></p>
    <p>Job: <%= contact.job %></p>
    <p>Company: <%= contact.company %></p>
    <p>LinkedIn: <%= contact.linkedin %></p>
    <p>Email: <%= contact.email %></p>
    <p>How we Meet: <%= contact.meet %></p>
    <p>Other: <%= contact.other %></p>
    <p>Message: <%= contact.message %></p>
    <p><%= contact.timestamp.toLocaleString() %></p>
    <a href="/contact">Back to contact form</a>
</body>
</html>