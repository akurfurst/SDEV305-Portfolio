<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles/admin.css">
    <title>Confirmed</title>
</head>
<body>
    <%- include('../views/nav') %>
    <h1>Confirmed!</h1>
    <p>Name: <%= contact.fname %> <%= contact.lname %></p>
    <p>Job: <%= contact.job %></p>
